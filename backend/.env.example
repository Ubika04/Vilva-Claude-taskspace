APP_NAME="Vilva Taskspace"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vilva.example.com
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=vilva_taskspace
DB_USERNAME=vilva_user
DB_PASSWORD=your_secure_db_password
DB_ROOT_PASSWORD=your_root_password

# ── Cache & Queue (Redis) ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

BROADCAST_DRIVER=log

# ── Horizon Queue Config ──────────────────────────────────────────────
QUEUE_NOTIFICATIONS=notifications
QUEUE_DEFAULT=default
QUEUE_HEAVY=heavy

# ── AWS / DigitalOcean Spaces ─────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=your_spaces_key
AWS_SECRET_ACCESS_KEY=your_spaces_secret
AWS_DEFAULT_REGION=nyc3
AWS_BUCKET=vilva-taskspace
AWS_URL=https://vilva-taskspace.nyc3.cdn.digitaloceanspaces.com
AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ──────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@vilva.example.com
MAIL_FROM_NAME="Vilva Taskspace"

# ── Sanctum ───────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=vilva.example.com

# ── Rate Limiting ──────────────────────────────────────────────────────
API_RATE_LIMIT=60
